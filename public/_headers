# Applied to all routes on the demo site (Cloudflare Pages).
# These headers enable cross-origin isolation for SharedArrayBuffer/OPFS.
# NOTE: Library consumers do NOT need these — the library handles
# WASM loading internally via blob URLs (see extractor.ts).
/*
  Cross-Origin-Embedder-Policy: credentialless
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: cross-origin
  Access-Control-Allow-Origin: *
